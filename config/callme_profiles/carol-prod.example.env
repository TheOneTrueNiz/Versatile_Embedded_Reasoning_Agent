# call-me profile: carol-prod
# Purpose: deterministic outbound call voice/persona for production.

export CALLME_PROFILE_NAME="${CALLME_PROFILE_NAME:-carol-prod}"
export CALLME_ASSISTANT_NAME="${CALLME_ASSISTANT_NAME:-Vera}"
export CALLME_GREETING_TEMPLATE="${CALLME_GREETING_TEMPLATE:-Hey {name}, it's Vera.}"

# Keep call-me on provider speech for deterministic greetings.
export CALLME_USE_PROVIDER_TTS="${CALLME_USE_PROVIDER_TTS:-1}"

# SMS/MMS tools are intentionally disabled in this profile until carrier policy
# allows reliable delivery for this project setup.
export CALLME_SMS_MODE="${CALLME_SMS_MODE:-off}"
export CALLME_SMS_ENABLED="${CALLME_SMS_ENABLED:-0}"
export CALLME_SMS_AUTOREPLY="${CALLME_SMS_AUTOREPLY:-0}"
export CALLME_SYNC_MESSAGING_WEBHOOK="${CALLME_SYNC_MESSAGING_WEBHOOK:-0}"

# Telnyx voice profile
export CALLME_TELNYX_TTS_VOICE="${CALLME_TELNYX_TTS_VOICE:-Telnyx.Natural.carol}"
export CALLME_TELNYX_TTS_SERVICE_LEVEL="${CALLME_TELNYX_TTS_SERVICE_LEVEL:-premium}"
export CALLME_TELNYX_TTS_LANGUAGE="${CALLME_TELNYX_TTS_LANGUAGE:-en-US}"
export CALLME_TELNYX_TTS_PAYLOAD_TYPE="${CALLME_TELNYX_TTS_PAYLOAD_TYPE:-text}"

# Playback timing
export CALLME_HANGUP_DELAY_MS="${CALLME_HANGUP_DELAY_MS:-1200}"

# Mobile push defaults (routes through Vera push service)
export CALLME_PUSH_ENABLED="${CALLME_PUSH_ENABLED:-1}"
export CALLME_PUSH_TITLE="${CALLME_PUSH_TITLE:-Vera}"
export CALLME_PUSH_API_URL="${CALLME_PUSH_API_URL:-http://127.0.0.1:8788/api/push/test}"

# Native mobile push defaults (FCM-backed route)
# Enabled now that native Android push client path exists.
export CALLME_NATIVE_PUSH_ENABLED="${CALLME_NATIVE_PUSH_ENABLED:-1}"
export CALLME_NATIVE_PUSH_TITLE="${CALLME_NATIVE_PUSH_TITLE:-Vera}"
export CALLME_NATIVE_PUSH_API_URL="${CALLME_NATIVE_PUSH_API_URL:-http://127.0.0.1:8788/api/push/native/test}"
